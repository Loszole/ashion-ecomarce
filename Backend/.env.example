# Backend Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ecommerce-db?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Payment Gateway (if implementing Stripe later)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Email Service (optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
